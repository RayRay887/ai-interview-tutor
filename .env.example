# Supabase — create a project at https://supabase.com
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase dashboard setup (required for email + password + 6-digit code):
# 1. Run supabase/schema.sql in the SQL Editor
# 2. Authentication → Providers → Email: enable Email provider
# 3. Authentication → Providers → Email: turn ON "Confirm email"
# 4. Authentication → Email Templates: use {{ .Token }} for the 6-digit OTP in templates
#    (Confirm signup + Magic link / OTP templates)
#
# OpenAI — local dev only (server-side via Vite, never commit this file):
OPENAI_API_KEY=sk-your-key-here
#
# AI voice in production: deploy supabase/functions/text-to-speech and run:
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase functions deploy text-to-speech
